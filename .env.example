SECRET_KEY=change-me-generate-a-new-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins for CORS (Next.js default: http://localhost:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Supabase: Project Settings -> Database -> Connection string (URI). Use Session mode (port 5432) for migrations.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Vercel deployment ---
# Set these in your Vercel project dashboard under Settings > Environment Variables
# ALLOWED_HOSTS=your-project.vercel.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# DEBUG=False
